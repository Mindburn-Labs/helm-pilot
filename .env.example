# ─── HELM Pilot Environment Variables ───
# Copy to .env and fill in values.
# See docs/env-reference.md for details.

# ─── Database ───
DATABASE_URL=postgresql://helm:helm@localhost:5432/helm_pilot
# For pg-boss background jobs (uses same DB by default)
# PGBOSS_DATABASE_URL=postgresql://helm:helm@localhost:5432/helm_pilot

# ─── Telegram ───
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
APP_URL=http://localhost:3100
# Owner chat ID for admin commands (optional, enables owner-gated commands)
# TELEGRAM_OWNER_CHAT_ID=

# ─── LLM Providers ───
# Primary: OpenRouter (multi-model routing)
OPENROUTER_API_KEY=
# Direct providers (optional, for fallback)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ─── Search & Ranking ───
# Cohere Rerank (optional, improves opportunity ranking)
# COHERE_API_KEY=

# ─── Object Storage (S3-compatible) ───
# Leave empty for local filesystem storage
# S3_ENDPOINT=
# S3_BUCKET=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_REGION=

# ─── Connectors (OAuth) ───
# Google (Gmail + Drive connector)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Optional override; defaults to ${APP_URL}/api/connectors/gmail/oauth/callback and /gdrive/oauth/callback
# GOOGLE_REDIRECT_URI=http://localhost:3100/api/connectors/gmail/oauth/callback

# GitHub connector
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# ─── Security ───
# Session secret (generate with: openssl rand -hex 32)
SESSION_SECRET=dev-state-secret-change-me
# Encryption key for tokens (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=dev-encryption-key-change-me
# Trust boundary budget (EUR)
# DAILY_BUDGET_MAX=500
# PER_TASK_BUDGET_MAX=100

# ─── Server ───
PORT=3100
NODE_ENV=development
LOG_LEVEL=info

# ─── CORS ───
# Comma-separated list of allowed origins (empty = allow all in dev)
ALLOWED_ORIGINS=http://localhost:3000

# ─── Fly.io (production only) ───
# FLY_APP_NAME=helm-pilot
# Note: For Fly Postgres, append ?sslmode=require to DATABASE_URL
