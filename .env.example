# ─── HELM Pilot Environment Variables ───
# Copy to .env and fill in values.
# See docs/env-reference.md for details.

# ─── Database ───
DATABASE_URL=postgresql://helm:helm@localhost:5432/helm_pilot
# For pg-boss background jobs (uses same DB by default)
# PGBOSS_DATABASE_URL=postgresql://helm:helm@localhost:5432/helm_pilot

# ─── Telegram ───
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
APP_URL=http://localhost:3100
# Owner chat ID for admin commands (optional, enables owner-gated commands)
# TELEGRAM_OWNER_CHAT_ID=

# ─── LLM Providers ───
# Primary: OpenRouter (multi-model routing)
OPENROUTER_API_KEY=
# Direct providers (optional, for fallback)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ─── Search & Ranking ───
# Cohere Rerank (optional, improves opportunity ranking)
# COHERE_API_KEY=

# ─── Object Storage (S3-compatible) ───
# Leave empty for local filesystem storage
STORAGE_PATH=./data/storage
# S3_ENDPOINT=
# S3_BUCKET=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_REGION=

# ─── Connectors (OAuth) ───
# Google (Gmail + Drive connector)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Optional override; defaults to ${APP_URL}/api/connectors/gmail/oauth/callback and /gdrive/oauth/callback
# GOOGLE_REDIRECT_URI=http://localhost:3100/api/connectors/gmail/oauth/callback

# GitHub connector
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# ─── Security ───
# Session secret (generate with: openssl rand -hex 32)
SESSION_SECRET=dev-state-secret-change-me
# Encryption key for tokens (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=dev-encryption-key-change-me
# Trust boundary budget (EUR)
# DAILY_BUDGET_MAX=500
# PER_TASK_BUDGET_MAX=100

# ─── Server ───
PORT=3100
NODE_ENV=development
LOG_LEVEL=info
PYTHON_BIN=./.venv-pipelines/bin/python
PLAYWRIGHT_BROWSERS_PATH=./.cache/ms-playwright
PATCHRIGHT_BROWSERS_PATH=./.cache/ms-patchright

# ─── CORS ───
# Comma-separated list of allowed origins (empty = allow all in dev)
ALLOWED_ORIGINS=http://localhost:3000

# ─── HELM Governance Sidecar ───
# URL of the HELM governance engine. Pilot routes LLM calls through this
# proxy so Guardian can enforce policy and emit signed receipts.
# In docker-compose this is http://helm:8080; for host dev point at localhost.
HELM_GOVERNANCE_URL=http://localhost:8420
HELM_HEALTH_URL=http://localhost:8421
# When set to 1 every LLM/tool call FAILS CLOSED if HELM is unreachable or denies.
# Set to 0 ONLY in development; production must keep this at 1.
HELM_FAIL_CLOSED=1
# Upstream LLM endpoint HELM forwards allowed requests to (OpenAI-compatible).
# Leave as OpenRouter default, or point at your provider of choice.
HELM_UPSTREAM_URL=https://openrouter.ai/api/v1
# Ed25519 signing key for evidence packs (generate fresh per deployment).
# Override with Docker secret / Fly secret in production. NEVER commit.
EVIDENCE_SIGNING_KEY=pilot-dev-ephemeral-key-change-me
# Pin a published HELM image instead of building from ../../../helm-oss
# HELM_IMAGE=ghcr.io/mindburn-labs/helm-oss:0.3.0
# HELM host ports (defaults to 8420 / 8421 to avoid clashing with dev tooling)
HELM_PORT=8420
HELM_HEALTH_PORT=8421
HELM_REGION=pilot-local

# ─── Fly.io (production only) ───
# FLY_APP_NAME=helm-pilot
# Note: For Fly Postgres, append ?sslmode=require to DATABASE_URL

# ─── Observability (Phase 13 Track D) ───
# Sentry exception capture. Leave blank to disable.
# Get DSN from https://sentry.io/settings/projects/<project>/keys/
# SENTRY_DSN=https://<public-key>@<org>.ingest.sentry.io/<project-id>
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1

# OpenTelemetry trace export. Leave blank to disable — the GenAI span
# wrappers in packages/shared/src/otel become no-ops. To enable tracing,
# install @opentelemetry/sdk-node + @opentelemetry/exporter-trace-otlp-http
# in your deployment image and set these two:
# OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
# OTEL_SERVICE_NAME=helm-pilot
# OTEL_SEMCONV_STABILITY_OPT_IN=gen_ai_latest_experimental

# Alertmanager (only used by infra/monitoring/alertmanager.yml)
# TELEGRAM_ALERT_CHAT_ID=-1001234567890
# ALERT_EMAIL=ops@mindburn.org
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=alerts@mindburn.org
# SMTP_PASS=your-smtp-password
# SMTP_FROM=alerts@mindburn.org

# ─── Langfuse (Phase 14 Track D, optional LLM tracing) ───
# Self-hostable OSS tracing with LLM-specific prompt/output/score/user
# indexing. When all three are set, packages/shared/src/observability/
# langfuse.ts dynamically imports the `langfuse` SDK and shadows each
# agent-loop iteration as a Langfuse generation. Shim is no-op when
# any var is unset. Install `langfuse` in the deployment image to use.
# LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# LANGFUSE_HOST=https://cloud.langfuse.com

# ─── Braintrust (Phase 14 Track D, optional eval + LLM-as-judge) ───
# Prompt regression suite + rubric scoring. When both are set,
# packages/shared/src/eval/braintrust.ts activates; used by the
# eval-drift.yml CI workflow (future) and the `grade_output` tool.
# BRAINTRUST_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# BRAINTRUST_PROJECT=helm-pilot
