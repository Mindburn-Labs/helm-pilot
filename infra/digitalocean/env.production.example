# DigitalOcean Droplet production environment.
# Copy this file to .env.production, fill real values, then deploy with:
#   ENV_FILE=.env.production bash infra/digitalocean/deploy.sh create
#   ENV_FILE=.env.production bash infra/digitalocean/deploy.sh deploy

DOMAIN=pilot.example.com
TLS_EMAIL=ops@example.com
APP_URL=https://pilot.example.com
ALLOWED_ORIGINS=https://pilot.example.com

POSTGRES_DB=helm_pilot
POSTGRES_USER=helm
POSTGRES_PASSWORD=change-me-with-openssl-rand-hex-32

SESSION_SECRET=change-me-with-openssl-rand-hex-32
ENCRYPTION_KEY=change-me-with-openssl-rand-hex-32
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=change-me-with-openssl-rand-hex-32

HELM_IMAGE=ghcr.io/mindburn-labs/helm-oss:latest
HELM_REGION=digitalocean
HELM_UPSTREAM_URL=https://openrouter.ai/api/v1
HELM_FAIL_CLOSED=1
EVIDENCE_SIGNING_KEY=change-me-with-openssl-rand-hex-32

# Provider keys stay on the HELM sidecar in production.
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

EMAIL_PROVIDER=smtp
EMAIL_FROM=HELM Pilot <onboarding@example.com>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

STORAGE_PROVIDER=local
BACKUP_DIR=/app/backups
BACKUP_CRON_SCHEDULE=0 3 * * *
