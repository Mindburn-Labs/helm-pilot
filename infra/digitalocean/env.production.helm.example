# DigitalOcean production HELM sidecar environment.
# Copy to .env.production.helm. Provider keys belong here, not in Pilot.

HELM_REGION=digitalocean
HELM_UPSTREAM_URL=https://openrouter.ai/api/v1
HELM_ENABLE_OPENAI_PROXY=1
EVIDENCE_SIGNING_KEY=change-me-with-openssl-rand-hex-32

# Set at least one upstream provider key for the HELM sidecar.
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
