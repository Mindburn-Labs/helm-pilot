# DigitalOcean production shared environment.
# Copy to .env.production.shared. This file is used by Docker Compose interpolation
# and may be loaded by multiple services. Do not put provider API keys here.

DOMAIN=pilot.example.com
TLS_EMAIL=ops@example.com
APP_URL=https://pilot.example.com
ALLOWED_ORIGINS=https://pilot.example.com

POSTGRES_DB=helm_pilot
HELM_POSTGRES_DB=helm_governance
POSTGRES_USER=helm
POSTGRES_PASSWORD=change-me-with-openssl-rand-hex-32

HELM_IMAGE=ghcr.io/mindburn-labs/helm-oss:latest
PILOT_IMAGE=helm-pilot:local
WEB_IMAGE=helm-pilot-web:local

STORAGE_PROVIDER=local
BACKUP_DIR=/app/backups
BACKUP_CRON_SCHEDULE=0 3 * * *
S3_ENDPOINT=https://fra1.digitaloceanspaces.com
S3_BUCKET=helm-pilot-prod-backups
S3_REGION=fra1
