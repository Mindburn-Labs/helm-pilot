# DigitalOcean production Pilot environment.
# Copy to .env.production.pilot. Do not add OPENROUTER_API_KEY, ANTHROPIC_API_KEY,
# OPENAI_API_KEY, or other direct LLM provider keys to this file.

SESSION_SECRET=change-me-with-openssl-rand-hex-32
ENCRYPTION_KEY=change-me-with-openssl-rand-hex-32
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=change-me-with-openssl-rand-hex-32

HELM_FAIL_CLOSED=1
RUN_MIGRATIONS_ON_STARTUP=false
HELM_LLM_MODEL=anthropic/claude-sonnet-4
METRICS_AUTH_TOKEN=change-me-with-openssl-rand-hex-32

# Resend is the recommended production email provider for founder self-hosting.
EMAIL_PROVIDER=resend
EMAIL_FROM=HELM Pilot <onboarding@pilot.mindburn.run>
RESEND_API_KEY=

# Required for production backup upload and restore-drill evidence.
S3_ACCESS_KEY=
S3_SECRET_KEY=
BACKUP_ENCRYPTION_PASSPHRASE=change-me-with-openssl-rand-hex-32

# SMTP is also supported. If EMAIL_PROVIDER=smtp, all non-empty SMTP fields
# below are required by the deploy doctor.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
