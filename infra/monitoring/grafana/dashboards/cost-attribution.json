{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Per-workspace + per-subagent LLM cost attribution + 7-day burn forecast (Phase 16 Track O).",
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "type": "stat",
      "title": "Total USD spend (last 7d)",
      "id": 1,
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(increase(helm_pilot_llm_cost_usd_total[7d]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Prompt cache savings (last 7d)",
      "id": 2,
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(increase(helm_pilot_llm_cache_savings_usd_total[7d]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD", "color": { "mode": "fixed", "fixedColor": "green" } }
      }
    },
    {
      "type": "stat",
      "title": "Projected monthly spend",
      "id": 3,
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "description": "Linear forecast: (last-7d spend) × 30/7. Crude but calibrated enough for budget alerts.",
      "targets": [
        {
          "expr": "sum(increase(helm_pilot_llm_cost_usd_total[7d])) * 30 / 7",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 800 }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Cache hit rate (last 1h)",
      "id": 4,
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(rate(helm_pilot_llm_cache_hit_total[1h])) / sum(rate(helm_pilot_llm_calls_total[1h]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.25 },
              { "color": "green", "value": 0.5 }
            ]
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "USD spend per workspace",
      "id": 10,
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (workspace) (rate(helm_pilot_llm_cost_usd_total[5m]))",
          "legendFormat": "{{workspace}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } }
    },
    {
      "type": "timeseries",
      "title": "USD spend per subagent",
      "id": 11,
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (subagent) (rate(helm_pilot_llm_cost_usd_total[5m]))",
          "legendFormat": "{{subagent}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } }
    },
    {
      "type": "bargauge",
      "title": "USD spend per provider (last 24h)",
      "id": 12,
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (provider) (increase(helm_pilot_llm_cost_usd_total[24h]))",
          "refId": "A",
          "legendFormat": "{{provider}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } },
      "options": { "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true }
    },
    {
      "type": "table",
      "title": "Top 10 subagents by spend (last 24h)",
      "id": 13,
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "topk(10, sum by (subagent, workspace) (increase(helm_pilot_llm_cost_usd_total[24h])))",
          "instant": true,
          "format": "table",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["cost", "phase-16", "track-o"],
  "time": { "from": "now-7d", "to": "now" },
  "timezone": "",
  "title": "HELM Pilot — Cost Attribution",
  "uid": "helm-pilot-cost",
  "version": 1
}
