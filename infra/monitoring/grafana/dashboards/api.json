{
  "annotations": { "list": [] },
  "editable": true,
  "panels": [
    {
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(pilot_http_requests_total[1m]))",
          "legendFormat": "total",
          "refId": "A"
        },
        {
          "expr": "sum by (status_code) (rate(pilot_http_requests_total[1m]))",
          "legendFormat": "{{status_code}}",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(pilot_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(pilot_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(pilot_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "title": "Error Rate (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(pilot_http_errors_total[5m])) / sum(rate(pilot_http_requests_total[5m]))",
          "legendFormat": "error rate",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Active Connections",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "pilot_active_connections",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Top Routes by Traffic",
      "type": "table",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "topk(10, sum by (route) (rate(pilot_http_requests_total[5m])))",
          "refId": "A",
          "format": "table"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 37,
  "tags": ["pilot"],
  "time": { "from": "now-1h", "to": "now" },
  "title": "Pilot — API",
  "version": 1
}
