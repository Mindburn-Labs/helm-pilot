{
  "name": "helm-pilot",
  "private": true,
  "version": "1.1.0",
  "description": "Open-source, self-hostable autonomous founder operating system",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*",
    "e2e"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "test:coverage": "turbo test:coverage",
    "test:e2e": "npm run test:e2e -w e2e",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:generate": "npm run generate -w packages/db",
    "db:migrate": "npm run migrate -w packages/db",
    "db:studio": "npm run studio -w packages/db",
    "db:push": "npm run migrate -w packages/db",
    "db:seed": "tsx scripts/seed.ts",
    "lint:tenancy": "tsx scripts/lint-tenancy.ts",
    "rotate:master-key": "tsx scripts/rotate-master-key.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "fast-check": "^3.23.0",
    "prettier": "^3.5.0",
    "tsx": "^4.19.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0"
  }
}
