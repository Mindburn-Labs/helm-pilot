  "policy_overlay": [
    {
      "rule_id": "external_email_requires_draft_preview",
      "description": "Any outbound email via gmail.send must be drafted first and previewed by the founder before send.",
      "applies_to": { "tool_names": ["gmail.send"] },
      "mode": "escalate"
    },
    {
      "rule_id": "deploy_requires_approval",
      "description": "First deploy per (connector, project) requires explicit founder approval. Subsequent deploys to the same target within 24h auto-allow unless code diff exceeds threshold.",
      "applies_to": { "tool_names": ["vercel.deploy", "digitalocean.deploy"] },
      "mode": "escalate_on_first_per_target"
    },
    {
      "rule_id": "financial_action_requires_approval",
      "description": "Any tool call that moves money or sets up billing escalates to the founder with a signed intent preview.",
      "applies_to": {
        "tool_names": [
          "stripe.charge",
          "stripe.subscription_create",
          "digitalocean.upgrade_plan",
          "vercel.upgrade_plan"
        ]
      },
      "mode": "escalate"
    },
    {
      "rule_id": "application_submit_requires_approval",
      "description": "Submitting an application to YC or any accelerator is an irreversible external action and must be confirmed.",
      "applies_to": { "tool_names": ["application.submit"] },
      "mode": "escalate"
    },
    {
      "rule_id": "external_post_requires_approval",
      "description": "Posts to ProductHunt, HN, Twitter/X, LinkedIn all escalate — launch distribution never happens autonomously.",
      "applies_to": {
        "tool_names": [
          "launch.post_producthunt",
          "launch.post_hackernews",
          "launch.post_twitter",
          "launch.post_linkedin"
        ]
      },
      "mode": "escalate"
    },
    {
      "rule_id": "llm_spend_hard_ceiling",
      "description": "Workspace-wide hard stop on daily LLM spend — even with approval — prevents runaway-loop bills.",
      "applies_to": { "action_class": "LLM_INFERENCE" },
      "mode": "hard_stop_on_daily_budget"
    },
    {
      "rule_id": "content_publication_requires_authenticity_audit",
      "description": "Content published to any external channel (blog, email, social) must pass the 12-signal authenticity audit with verdict=authentic before publication. AI-tell content fails.",
      "applies_to": {
        "tool_names": [
          "blog.publish",
          "gmail.send",
          "launch.post_producthunt",
          "launch.post_hackernews",
          "launch.post_twitter",
          "launch.post_linkedin"
        ]
      },
      "mode": "escalate"
    },
    {
      "rule_id": "ad_spend_change_requires_approval",
      "description": "Any change that increases daily ad spend or starts a new campaign escalates. Pausing or decreasing spend auto-allows.",
      "applies_to": {
        "tool_names": [
          "google_ads.create_campaign",
          "google_ads.increase_budget",
          "meta_ads.create_campaign",
          "meta_ads.increase_budget"
        ]
      },
      "mode": "escalate"
    },
    {
      "rule_id": "finance_read_only_by_default",
      "description": "Finance operator is read-only by policy. Writes to Stripe (charge, refund, subscription change) always escalate.",
      "applies_to": {
        "tool_names": [
          "stripe.charge",
          "stripe.refund",
          "stripe.subscription_update",
          "stripe.subscription_cancel"
        ]
      },
      "mode": "escalate"
    },
    {
      "rule_id": "diagnose_no_writes",
      "description": "Diagnose mode is strictly read-only. Writes from any diagnose operator deny outright — diagnosis produces recommendations, not actions.",
      "applies_to": {
        "employee_roles": ["diagnose"],
        "tool_match": "*.write_*|*.create_*|*.update_*|*.delete_*|*.send*|*.post_*"
      },
      "mode": "deny"
    }
  ],

