{
  "pack_id": "founder-ops-v1",
  "label": "Founder Operations",
  "description": "Governs the founder loop — opportunity discovery, cofounder assessment, MVP building, launch preparation, and accelerator applications — for a single-founder workspace running HELM Pilot.",
  "version": 1,

  "programs": [
    {
      "program_id": "prog-founder-intake",
      "label": "Founder Intake",
      "status": "active",
      "signal_filters": [{ "class": "PROFILE_UPDATE" }, { "class": "ASSESSMENT_COMPLETED" }]
    },
    {
      "program_id": "prog-opportunity-discovery",
      "label": "Opportunity Discovery",
      "status": "active",
      "signal_filters": [
        {
          "class": "OPPORTUNITY_INGESTED",
          "source": ["yc", "hn", "producthunt", "indiehackers", "github", "crunchbase"]
        },
        { "class": "OPPORTUNITY_SCORED" }
      ]
    },
    {
      "program_id": "prog-cofounder-assessment",
      "label": "Cofounder Assessment",
      "status": "active",
      "signal_filters": [
        { "class": "CANDIDATE_IMPORTED" },
        { "class": "CANDIDATE_SCORED" },
        { "class": "OPERATOR_RECOMMENDED" }
      ]
    },
    {
      "program_id": "prog-decision-court",
      "label": "Decision Court",
      "status": "active",
      "signal_filters": [
        { "class": "DECISION_REQUESTED" },
        { "class": "DEBATE_COMPLETED" },
        { "class": "VERDICT_ISSUED" }
      ]
    },
    {
      "program_id": "prog-mvp-build",
      "label": "MVP Build",
      "status": "active",
      "signal_filters": [
        { "class": "SPEC_GENERATED" },
        { "class": "SCAFFOLD_CREATED" },
        { "class": "COMMIT_ATTEMPTED" },
        { "class": "PR_OPENED" }
      ]
    },
    {
      "program_id": "prog-launch-prep",
      "label": "Launch Preparation",
      "status": "active",
      "signal_filters": [
        { "class": "DEPLOY_ATTEMPTED", "provider_class": ["vercel", "digitalocean"] },
        { "class": "DISTRIBUTION_DRAFTED" },
        { "class": "EXTERNAL_POST_REQUESTED" }
      ]
    },
    {
      "program_id": "prog-yc-application",
      "label": "YC / Accelerator Application",
      "status": "active",
      "signal_filters": [
        { "class": "APPLICATION_DRAFTED" },
        { "class": "APPLICATION_EDITED" },
        { "class": "APPLICATION_SUBMITTED" }
      ]
    },
    {
      "program_id": "prog-content-pipeline",
      "label": "Content Pipeline",
      "status": "active",
      "signal_filters": [
        {
          "class": "CONTENT_GENERATED",
          "content_type": ["blog_post", "email", "social_post", "video_script", "landing_copy"]
        },
        { "class": "AUTHENTICITY_AUDIT_COMPLETED" }
      ]
    },
    {
      "program_id": "prog-seo-geo",
      "label": "SEO + Generative Engine Optimization",
      "status": "active",
      "signal_filters": [
        { "class": "SEO_AUDIT_REQUESTED" },
        { "class": "SCHEMA_MARKUP_GENERATED" },
        { "class": "AI_SEARCH_VISIBILITY_CHECK" }
      ]
    },
    {
      "program_id": "prog-finance-intelligence",
      "label": "Finance Intelligence",
      "status": "active",
      "signal_filters": [
        { "class": "REVENUE_RECORDED" },
        { "class": "MRR_SNAPSHOT" },
        { "class": "UNIT_ECONOMICS_CALCULATED" }
      ]
    },
    {
      "program_id": "prog-diagnose",
      "label": "Business Diagnosis",
      "status": "active",
      "signal_filters": [{ "class": "DIAGNOSIS_REQUESTED" }, { "class": "WORKSPACE_STUCK_SIGNAL" }]
    }
  ],

